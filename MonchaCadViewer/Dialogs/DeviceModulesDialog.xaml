<Window
    x:Class="CadProjectorViewer.Dialogs.DeviceModulesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:dat="clr-namespace:System.Windows.Data;assembly=PresentationFramework"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:devices="clr-namespace:CadProjectorViewer.ViewModel.Devices"
    xmlns:local="clr-namespace:CadProjectorViewer.Dialogs"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="{Binding DialogTitle}"
    Width="850"
    Height="450"
    d:DataContext="{d:DesignInstance Type=devices:AddDeviceModule}"
    FontSize="16"
    WindowStyle="ToolWindow"
    mc:Ignorable="d">
    <Window.Resources>
        <dat:ObjectDataProvider
            x:Key="DeviceModulesStageValues"
            MethodName="GetValues"
            ObjectType="{x:Type sys:Enum}">
            <dat:ObjectDataProvider.MethodParameters>
                <x:Type TypeName="devices:DeviceModulesStage" />
            </dat:ObjectDataProvider.MethodParameters>
        </dat:ObjectDataProvider>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style TargetType="MenuItem">
            <Setter Property="Header" Value="{Binding Name}" />
            <Setter Property="Command" Value="{Binding DataContext.AddModuleCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" />
            <Setter Property="CommandParameter" Value="{Binding .}" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <DockPanel
            Grid.Row="0"
            LastChildFill="False"
            Margin="3">
            <Label Content="Группа:" />
            <ComboBox
                Width="180"
                ItemsSource="{Binding Source={StaticResource DeviceModulesStageValues}}"
                SelectedItem="{Binding SelectedStage}" />
        </DockPanel>
        <Grid
            Grid.Row="1"
            Margin="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                BorderBrush="Black"
                BorderThickness="1">
                <ListView
                    d:ItemsSource="{d:SampleData ItemCount=3}"
                    AllowDrop="True"
                    ItemsSource="{Binding DeviceModules}"
                    SelectedItem="{Binding SelectModule}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Drop="StackPanel_Drop" Orientation="Horizontal">
                                <Label
                                    VerticalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="&gt;::&gt;"
                                    Cursor="SizeNS"
                                    MouseDown="Label_MouseDown" />
                                <CheckBox IsChecked="{Binding IsOn}" />
                                <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                <Button
                                    Margin="3,0,0,0"
                                    Command="{Binding ShowCommand}"
                                    Content="Show"
                                    Visibility="{Binding CanShow, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
            <Border
                Grid.Column="2"
                BorderBrush="Black"
                BorderThickness="1">
                <ContentControl Content="{Binding SelectModule}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type devices:DeviceModuleViewModel}">
                            <local:ModulesEditor />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button Command="{Binding RemoveModuleCommand}" Content="Remove" />
            <mah:DropDownButton
                Content="Add"
                DockPanel.Dock="Right"
                ItemsSource="{Binding AvailableType}" />

        </DockPanel>

    </Grid>
</Window>
