<UserControl
    x:Class="CadProjectorViewer.Dialogs.ModulesEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CadProjectorViewer.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/ModulesTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <StackPanel Margin="10">
            <TextBlock
                FontWeight="SemiBold"
                Text="{Binding GroupDisplayName}" />
            <TextBlock
                Margin="0,2,0,8"
                Foreground="DimGray"
                Text="{Binding Name}" />
            <ContentControl
                Content="{Binding Module}"
                ContentTemplate="{StaticResource BaseModule}" />
        </StackPanel>
    </Grid>
</UserControl>
